# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or any file with real keys.

# The Odds API — get key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# OpenAI — used by app/api/generate/narrative
OPENAI_API_KEY=your_openai_key_here

# V11 Decision Engine (optional, falls back to local compute if unset)
V11_API_URL=http://localhost:8811

# Backend URL (optional, frontend calls Odds API directly now)
BACKEND_URL=http://localhost:8000
