{
  "name": "mosport",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "db:migrate:deploy": "prisma migrate deploy",
    "start:railway": "npm run db:migrate:deploy && npm start -- -p ${PORT:-3000}",
    "audit:logos": "tsx scripts/audit-logos.ts",
    "security:scan": "tsx scripts/security/scan-secrets.ts",
    "security:token-age": "tsx scripts/security/check-token-age.ts",
    "security:agent": "tsx -e \"import('./security/agent').then(m => console.log(m.runSecurityAgent()))\"",
    "check:secrets": "tsx scripts/check-no-env-secrets.ts",
    "check:prisma": "tsx scripts/check-prisma-imports.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@upstash/qstash": "^2.10.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.475.0",
    "ml-matrix": "^6.12.1",
    "ml-random-forest": "^2.1.0",
    "next": "^15.2.8",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shuffle-array": "^1.0.1",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.19",
    "eslint": "^9",
    "eslint-config-next": "15.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
