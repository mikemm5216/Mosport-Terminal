{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build"
  },
  "deploy": {
    "startCommand": "./node_modules/.bin/prisma migrate deploy && npm start -- -p ${PORT:-3000}",
    "healthcheckPath": "/api/admin/ingest/hot",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
