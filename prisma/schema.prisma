generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["quant_internal", "public_api", "ghost_layer"]
}

model Teams {
  team_id      String         @id @default(cuid())
  league_type  LeagueType
  full_name    String         @unique
  short_name   String
  city         String?
  home_venue   String?
  logo_url     String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  history      MatchHistory[]
  matches_away Match[]        @relation("AwayMatches")
  matches_home Match[]        @relation("HomeMatches")
  rosters      Roster[]

  @@schema("public_api")
}

model Player {
  player_id     String        @id @default(cuid())
  first_name    String
  last_name     String
  display_name  String
  nationality   String?
  position_main String
  active_status Boolean       @default(true)
  created_at    DateTime      @default(now())
  rosters       Roster[]
  stats_mlb     Stats_MLB?
  stats_nba     Stats_NBA?
  stats_soccer  Stats_Soccer?

  @@schema("public_api")
}

model Roster {
  id            String  @id @default(cuid())
  player_id     String
  team_id       String
  season_year   Int
  jersey_number String?
  player        Player  @relation(fields: [player_id], references: [player_id])
  team          Teams   @relation(fields: [team_id], references: [team_id])

  @@unique([player_id, team_id, season_year])
  @@schema("public_api")
}

model Stats_NBA {
  player_id String @id
  pts       Float?
  reb       Float?
  ast       Float?
  player    Player @relation(fields: [player_id], references: [player_id])

  @@schema("public_api")
}

model Stats_MLB {
  player_id String @id
  avg       Float?
  hr        Int?
  rbi       Int?
  era       Float?
  w         Int?
  so        Int?
  player    Player @relation(fields: [player_id], references: [player_id])

  @@schema("public_api")
}

model Stats_Soccer {
  player_id String @id
  goals     Int?
  assists   Int?
  saves     Int?
  player    Player @relation(fields: [player_id], references: [player_id])

  @@schema("public_api")
}

model Match {
  id           String   @id @default(cuid()) @map("match_id")
  extId        String   @unique
  date         DateTime @map("match_date")
  sport        String

  homeTeamId   String   @map("home_team_id")
  awayTeamId   String   @map("away_team_id")
  
  home_team    Teams    @relation("HomeMatches", fields: [homeTeamId], references: [team_id])
  away_team    Teams    @relation("AwayMatches", fields: [awayTeamId], references: [team_id])

  homeTeamName String
  awayTeamName String

  homeScore    Int?     @map("home_score")
  awayScore    Int?     @map("away_score")

  matchResult  String?
  status       String   @default("scheduled")

  leagueId     String?  @map("league_id")
  league       League?  @relation(fields: [leagueId], references: [id])

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  features     MatchFeatures[]
  odds         Odds[]
  snapshots    EventSnapshot[]
  mappings     ExternalMatchMap[]

  predictions  MatchPrediction[]
  signals      MatchSignal[]
  
  nbaStats     MatchStatsNBA?
  footballStats MatchStatsFootball?
  baseballStats MatchStatsBaseball?

  @@index([sport, date])
  @@map("Matches")
  @@schema("quant_internal")
}

model League {
  id              String   @id
  name            String?  @unique
  sport           String   // 'football', 'basketball', 'baseball'
  hasDraw         Boolean? @default(false)
  matchDuration   Int?     @default(90)
  isKnockout      Boolean? @default(false)
  logo_url        String?
  matches         Match[]

  @@schema("quant_internal")
}

model MatchStatsFootball {
  matchId       String   @id @map("match_id")
  homeXG        Float
  awayXG        Float
  homePoss      Float
  awayPoss      Float
  homeShots     Int
  awayShots     Int
  homeSot       Int
  awaySot       Int
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@schema("quant_internal")
}

model MatchStatsBaseball {
  matchId       String   @id @map("match_id")
  homeStarterId String?
  awayStarterId String?
  homeXFIP      Float?
  awayXFIP      Float?
  homeWRC       Float?
  awayWRC       Float?
  startingPitcherConfirmed Boolean @default(false)
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@schema("quant_internal")
}

model MatchStatsNBA {
  matchId       String   @id @map("match_id")
  homeFga       Int
  homeFta       Int
  homeTov       Int
  homeOreb      Int
  homeReb       Int
  homeAst       Int
  awayFga       Int
  awayFta       Int
  awayTov       Int
  awayOreb      Int
  awayReb       Int
  awayAst       Int
  homePlayerIds String[] // For Starter Consistency Proxy
  awayPlayerIds String[]
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@schema("quant_internal")
}

model MatchPrediction {
  id           String   @id @default(cuid())
  matchId      String   @unique @map("match_id")
  homeWinProb  Float    @map("home_win_prob")
  awayWinProb  Float    @map("away_win_prob")
  updatedAt    DateTime @updatedAt @map("updated_at")
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@schema("public_api")
}

model MatchSignal {
  id           String   @id @default(cuid())
  matchId      String   @unique @map("match_id")
  signalLabel  String   @map("signal_label") // LEAN, STRONG, ELITE
  signalScore  Float    @map("signal_score")
  
  // V11.5 Metrics
  edge         Float?   @default(0)
  ev           Float?   @default(0)
  ra_ev        Float?   @default(0) // Risk-Adjusted EV
  clv          Float?   @default(0) // Closing Line Value
  confidence   Float?   @default(0)
  tags         String[] @default([])
  marketFairProbs Json?

  updatedAt    DateTime @updatedAt @map("updated_at")
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@schema("public_api")
}

model MatchFeatures {
  id              String   @id @default(cuid())
  matchId         String   @map("match_id")
  sport           String

  homeWorld       Float?
  awayWorld       Float?
  homePhysio      Float?
  awayPhysio      Float?
  homePsycho      Float?
  awayPsycho      Float?

  worldDiff       Float?
  physioDiff      Float?
  psychoDiff      Float?

  featureTime     DateTime @default(now())
  featureVersion  String
  updatedAt       DateTime @updatedAt
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, sport, featureVersion])
  @@schema("quant_internal")
}

model EventSnapshot {
  snapshot_id   String   @id @default(uuid()) @db.Uuid
  matchId       String   @map("match_id")
  snapshot_type String
  state_json    Json
  created_at    DateTime @default(now())
  status        String   @default("DRAFT")
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@schema("quant_internal")
}

model MatchHistory {
  id      String   @id @default(cuid())
  team_id String
  result  String
  date    DateTime
  team    Teams    @relation(fields: [team_id], references: [team_id])

  @@schema("public_api")
}

model ExternalMatchMap {
  id          String   @id @default(cuid())
  matchId     String
  provider    String
  extId       String
  match_date  DateTime
  home_team   String
  away_team   String
  created_at  DateTime @default(now())
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([provider, extId])
  @@schema("quant_internal")
}

model RawEvents {
  id         String   @id @default(cuid())
  extId      String
  provider   String
  sport      String
  league     String
  payload    Json
  hash       String
  processed  Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([extId, provider])
  @@schema("quant_internal")
}

model Odds {
  id         String   @id @default(cuid())
  matchId    String
  provider   String
  odds_json  Json
  fetched_at DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@schema("quant_internal")
}

model IngestionState {
  id          String   @id @default(cuid())
  provider    String   @default("thesportsdb")
  sport       String
  league      String
  currentPage Int      @default(1)
  status      String   @default("pending")
  retryCount  Int      @default(0)
  lastRunAt   DateTime @default(now())

  @@unique([provider, sport, league])
  @@schema("quant_internal")
}

model IngestionErrors {
  id           String   @id @default(cuid())
  provider     String
  extId        String?
  errorMessage String
  payload      Json?
  createdAt    DateTime @default(now())

  @@schema("quant_internal")
}

model MatchResolutionLog {
  id               String   @id @default(cuid())
  inputProvider    String
  inputExtId       String
  candidateMatchId String?
  finalMatchId     String?
  score            Float?
  decision         String
  factors          Json?
  confidenceLevel  String?
  created_at       DateTime @default(now())

  @@schema("quant_internal")
}

enum LeagueType {
  NBA
  MLB
  FOOTBALL
  FIBA
  CPBL
  NPB
  KBO

  @@schema("public_api")
}

// --- V13.0 GHOST LAYER MODELS ---

model UserEventLog {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  action    String   // VIEW, FOLLOW, IGNORE
  modelVersion String? // V13+ Model Versioning
  metadata  Json?
  createdAt DateTime @default(now())

  @@schema("ghost_layer")
}

model StrategyPerformanceSnapshot {
  id           String   @id @default(cuid())
  strategyName String
  metrics      Json
  recordedAt   DateTime @default(now())

  @@schema("ghost_layer")
}

model UserProfileVector {
  id                String   @id @default(cuid())
  userId            String   @unique
  riskPreference    Float    @default(0.5)
  edgePreference    Float    @default(0.03)
  oddsPreference    Float    @default(2.0)
  preferenceVector  Json?
  lastBehaviorAudit DateTime @default(now())

  @@schema("ghost_layer")
}

model SignalOutcome {
  id           String   @id @default(cuid())
  signalId     String   @unique
  result       String   // WIN, LOSE, DRAW
  payout       Float
  closingOdds  Float
  recordedAt   DateTime @default(now())

  @@schema("ghost_layer")
}

model StrategyBacktestResult {
  id           String   @id @default(cuid())
  league       String
  strategyType String   // FLAT, WEIGHTED, KELLY
  simulatedROI Float
  sharpeRatio  Float
  maxDrawdown  Float
  sampleSize   Int
  robustness   String   // HIGH_ROBUSTNESS, LOW_ROBUSTNESS
  updatedAt    DateTime @default(now())

  @@schema("ghost_layer")
}
