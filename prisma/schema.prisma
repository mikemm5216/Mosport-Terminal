generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teams {
  team_id      String         @id @default(cuid())
  league_type  LeagueType
  full_name    String         @unique
  short_name   String
  city         String?
  home_venue   String?
  logo_url     String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  history      MatchHistory[]
  matches_away Matches[]      @relation("AwayMatches")
  matches_home Matches[]      @relation("HomeMatches")
  rosters      Roster[]
}

model Player {
  player_id     String        @id @default(cuid())
  first_name    String
  last_name     String
  display_name  String
  nationality   String?
  position_main String
  active_status Boolean       @default(true)
  created_at    DateTime      @default(now())
  rosters       Roster[]
  stats_mlb     Stats_MLB?
  stats_nba     Stats_NBA?
  stats_soccer  Stats_Soccer?
}

model Roster {
  id            String  @id @default(cuid())
  player_id     String
  team_id       String
  season_year   Int
  jersey_number String?
  player        Player  @relation(fields: [player_id], references: [player_id])
  team          Teams   @relation(fields: [team_id], references: [team_id])

  @@unique([player_id, team_id, season_year])
}

model Stats_NBA {
  player_id String @id
  pts       Float?
  reb       Float?
  ast       Float?
  player    Player @relation(fields: [player_id], references: [player_id])
}

model Stats_MLB {
  player_id String @id
  avg       Float?
  hr        Int?
  rbi       Int?
  era       Float?
  w         Int?
  so        Int?
  player    Player @relation(fields: [player_id], references: [player_id])
}

model Stats_Soccer {
  player_id String @id
  goals     Int?
  assists   Int?
  saves     Int?
  player    Player @relation(fields: [player_id], references: [player_id])
}

model Matches {
  match_id        String          @id @default(cuid())
  extId           String          @unique
  home_team_id    String
  away_team_id    String
  match_date      DateTime
  status          String
  home_score      Int?
  away_score      Int?
  league          String?
  sport           String?
  sourceUpdatedAt DateTime?
  created_at      DateTime        @default(now())
  snapshots       EventSnapshot[]
  away_team       Teams           @relation("AwayMatches", fields: [away_team_id], references: [team_id])
  home_team       Teams           @relation("HomeMatches", fields: [home_team_id], references: [team_id])
  odds            Odds[]
}

model EventSnapshot {
  snapshot_id   String   @id @default(uuid()) @db.Uuid
  match_id      String
  snapshot_type String
  state_json    Json
  created_at    DateTime @default(now())
  status        String   @default("DRAFT")
  match         Matches  @relation(fields: [match_id], references: [match_id])
}

model MatchHistory {
  id      String   @id @default(cuid())
  team_id String
  result  String
  date    DateTime
  team    Teams    @relation(fields: [team_id], references: [team_id])
}

model ExternalMatchMap {
  id          String   @id @default(cuid())
  external_id String   @unique
  internal_id String
  provider    String
  match_date  DateTime
  home_team   String
  away_team   String
  created_at  DateTime @default(now())

  @@index([match_date])
}

model RawEvents {
  id         String   @id @default(cuid())
  extId      String
  provider   String
  sport      String
  league     String
  payload    Json
  hash       String
  processed  Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([extId, provider])
  @@index([sport, league])
}

model Odds {
  id         String   @id @default(cuid())
  matchId    String
  provider   String
  odds_json  Json
  fetched_at DateTime @default(now())
  match      Matches  @relation(fields: [matchId], references: [match_id])

  @@index([matchId, fetched_at])
}

model IngestionState {
  id          String   @id @default(cuid())
  sport       String
  league      String
  currentPage Int      @default(1)
  status      String   @default("pending")
  lastRunAt   DateTime @default(now())

  @@unique([sport, league])
}

model IngestionErrors {
  id         String   @id @default(cuid())
  extId      String?
  provider   String
  payload    Json?
  error      String
  stack      String?
  severity   String   @default("CRITICAL")
  resolved   Boolean  @default(false)
  created_at DateTime @default(now())
}

enum LeagueType {
  NBA
  MLB
  SOCCER
}
