generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public_api"]
}

model Player {
  public_uuid   String   @id @default(uuid()) @db.Uuid
  internal_code String   @unique
  full_name     String
  created_at    DateTime @default(now())

  stats_logs StatsLog[]

  @@index([internal_code])
  @@schema("public_api")
}

model Context {
  public_uuid   String @id @default(uuid()) @db.Uuid
  internal_code String @unique
  sport_code    String
  weight_level  String
  team_code     String
  name          String

  stats_logs StatsLog[]

  @@index([internal_code])
  @@schema("public_api")
}

model StatsLog {
  id                    String   @id @default(cuid())
  player_internal_code  String
  context_internal_code String
  metric_type           String
  value                 Float
  timestamp             DateTime @default(now())

  player  Player  @relation(fields: [player_internal_code], references: [internal_code])
  context Context @relation(fields: [context_internal_code], references: [internal_code])

  @@index([player_internal_code])
  @@index([context_internal_code])
  @@schema("public_api")
}
