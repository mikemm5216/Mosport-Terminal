generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teams {
  team_id      String         @id @default(cuid())
  league_type  LeagueType
  full_name    String         @unique
  short_name   String
  city         String?
  home_venue   String?
  logo_url     String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  history      MatchHistory[]
  matches_away Match[]        @relation("AwayMatches")
  matches_home Match[]        @relation("HomeMatches")
  rosters      Roster[]
}

model Player {
  player_id     String        @id @default(cuid())
  first_name    String
  last_name     String
  display_name  String
  nationality   String?
  position_main String
  active_status Boolean       @default(true)
  created_at    DateTime      @default(now())
  rosters       Roster[]
  stats_mlb     Stats_MLB?
  stats_nba     Stats_NBA?
  stats_soccer  Stats_Soccer?
}

model Roster {
  id            String  @id @default(cuid())
  player_id     String
  team_id       String
  season_year   Int
  jersey_number String?
  player        Player  @relation(fields: [player_id], references: [player_id])
  team          Teams   @relation(fields: [team_id], references: [team_id])

  @@unique([player_id, team_id, season_year])
}

model Stats_NBA {
  player_id String @id
  pts       Float?
  reb       Float?
  ast       Float?
  player    Player @relation(fields: [player_id], references: [player_id])
}

model Stats_MLB {
  player_id String @id
  avg       Float?
  hr        Int?
  rbi       Int?
  era       Float?
  w         Int?
  so        Int?
  player    Player @relation(fields: [player_id], references: [player_id])
}

model Stats_Soccer {
  player_id String @id
  goals     Int?
  assists   Int?
  saves     Int?
  player    Player @relation(fields: [player_id], references: [player_id])
}

model Match {
  id           String   @id @default(cuid()) @map("match_id")
  extId        String   @unique
  date         DateTime @map("match_date")
  sport        String   // "baseball" | "basketball" | "football"

  homeTeamId   String   @map("home_team_id")
  awayTeamId   String   @map("away_team_id")
  
  home_team    Teams    @relation("HomeMatches", fields: [homeTeamId], references: [team_id])
  away_team    Teams    @relation("AwayMatches", fields: [awayTeamId], references: [team_id])

  homeTeamName String   // display only
  awayTeamName String

  homeScore    Int?     @map("home_score")
  awayScore    Int?     @map("away_score")

  matchResult  String?  // "HOME_WIN" | "AWAY_WIN" | "DRAW"
  status       String   @default("scheduled")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  features     MatchFeatures[]
  odds         Odds[]
  snapshots    EventSnapshot[]
  mappings     ExternalMatchMap[]

  @@index([sport, date])
  @@map("Matches")
}

model MatchFeatures {
  id              String   @id @default(cuid())
  matchId         String   @map("match_id")
  sport           String

  // 🌍 World Engine
  homeWorld       Float?
  awayWorld       Float?

  // 🫀 Physio Engine
  homePhysio      Float?
  awayPhysio      Float?

  // 🧠 Psycho Engine
  homePsycho      Float?
  awayPsycho      Float?

  // Derived (useful for training)
  worldDiff       Float?
  physioDiff      Float?
  psychoDiff      Float?

  featureTime     DateTime @default(now())
  featureVersion  String
  updatedAt       DateTime @updatedAt

  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, sport, featureVersion])
  @@index([matchId, sport])
}

model EventSnapshot {
  snapshot_id   String   @id @default(uuid()) @db.Uuid
  matchId       String   @map("match_id")
  snapshot_type String
  state_json    Json
  created_at    DateTime @default(now())
  status        String   @default("DRAFT")
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model MatchHistory {
  id      String   @id @default(cuid())
  team_id String
  result  String
  date    DateTime
  team    Teams    @relation(fields: [team_id], references: [team_id])
}

model ExternalMatchMap {
  id          String   @id @default(cuid())
  matchId     String
  provider    String
  extId       String
  match_date  DateTime
  home_team   String
  away_team   String
  created_at  DateTime @default(now())

  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([provider, extId])
  @@index([matchId])
}

model RawEvents {
  id         String   @id @default(cuid())
  extId      String
  provider   String
  sport      String
  league     String
  payload    Json
  hash       String
  processed  Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([extId, provider])
  @@index([sport, league])
}

model Odds {
  id         String   @id @default(cuid())
  matchId    String
  provider   String
  odds_json  Json
  fetched_at DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, fetched_at])
}

model IngestionState {
  id          String   @id @default(cuid())
  provider    String   @default("thesportsdb")
  sport       String
  league      String
  currentPage Int      @default(1)
  status      String   @default("pending") // pending, running, failed, done
  retryCount  Int      @default(0)
  lastRunAt   DateTime @default(now())

  @@unique([provider, sport, league])
}

model IngestionErrors {
  id           String   @id @default(cuid())
  provider     String
  extId        String?
  errorMessage String
  payload      Json?
  createdAt    DateTime @default(now())
}

model MatchResolutionLog {
  id               String   @id @default(cuid())
  inputProvider    String
  inputExtId       String
  candidateMatchId String?
  finalMatchId     String?
  score            Float?
  decision         String   // matched, created
  factors          Json?    // teamSimilarity, timeScore, leagueScore
  confidenceLevel  String?  // high, medium, low
  created_at       DateTime @default(now())

  @@index([inputProvider, inputExtId])
}

enum LeagueType {
  NBA
  MLB
  SOCCER
}
