generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// DIRECTIVE 1.1: Strict League Enum
enum LeagueType {
  NBA
  MLB
  SOCCER
}

// DIRECTIVE 1.2: Core Units
model Teams {
  team_id     String     @id @default(cuid())
  league_type LeagueType
  full_name   String     @unique
  short_name  String     // CEO Standard TLA (LAL, LAD, WHU)
  city        String?
  home_venue  String?
  logo_url    String?    // Seeded from permanent CDNs
  
  rosters     Roster[]
  matches_home Matches[] @relation("HomeMatches")
  matches_away Matches[] @relation("AwayMatches")
  history      MatchHistory[]
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
}

// DIRECTIVE 1.3: Identity & Professional Roster
model Player {
  player_id     String    @id @default(cuid())
  first_name    String
  last_name     String
  display_name  String
  nationality   String?
  position_main String
  active_status Boolean   @default(true)
  
  rosters      Roster[]
  stats_nba    Stats_NBA?
  stats_mlb    Stats_MLB?
  stats_soccer Stats_Soccer?
  created_at    DateTime  @default(now())
}

model Roster {
  id            String   @id @default(cuid())
  player_id     String
  team_id       String
  season_year   Int
  jersey_number String?
  
  player        Player   @relation(fields: [player_id], references: [player_id])
  team          Teams    @relation(fields: [team_id], references: [team_id])

  @@unique([player_id, team_id, season_year])
}

// DIRECTIVE 1.4: Separated Data Streams
model Stats_NBA {
  player_id   String  @id
  pts         Float?
  reb         Float?
  ast         Float?
  player      Player  @relation(fields: [player_id], references: [player_id])
}

model Stats_MLB {
  player_id   String  @id
  avg         Float?
  hr          Int?
  rbi         Int?
  era         Float?  // Pitching: Earned Run Average
  w           Int?    // Pitching: Wins
  so          Int?    // Pitching: Strikeouts
  player      Player  @relation(fields: [player_id], references: [player_id])
}

model Stats_Soccer {
  player_id   String  @id
  goals       Int?
  assists     Int?
  saves       Int?
  player      Player  @relation(fields: [player_id], references: [player_id])
}

// Operational Matches
model Matches {
  match_id       String   @id @default(cuid())
  home_team_id   String
  away_team_id   String
  match_date     DateTime
  status         String   // scheduled, live, finished
  home_score     Int?
  away_score     Int?
  
  home_team      Teams    @relation("HomeMatches", fields: [home_team_id], references: [team_id])
  away_team      Teams    @relation("AwayMatches", fields: [away_team_id], references: [team_id])
  
  snapshots      EventSnapshot[]
  created_at     DateTime @default(now())
}

// Analytics Layers
model EventSnapshot {
  snapshot_id   String   @id @default(uuid()) @db.Uuid
  match_id      String
  snapshot_type String   // T-24h / T-6h / T-1h / T-10min
  state_json    Json
  created_at    DateTime @default(now())
  status        String   @default("DRAFT") // FINALIZED, DRAFT
  
  match         Matches  @relation(fields: [match_id], references: [match_id])
}

model MatchHistory {
  id        String   @id @default(cuid())
  team_id   String
  result    String   // 'W', 'L', 'D'
  date      DateTime
  
  team      Teams    @relation(fields: [team_id], references: [team_id])
}

model ExternalMatchMap {
  id           String   @id @default(cuid())
  external_id  String   @unique
  internal_id  String
  provider     String   // e.g., "TheOddsAPI"
  match_date   DateTime
  home_team    String
  away_team    String
  created_at   DateTime @default(now())

  @@index([match_date])
}
