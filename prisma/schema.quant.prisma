generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma-quant"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id           String   @id @default(cuid()) @map("match_id")
  extId        String   @unique
  date         DateTime @map("match_date")
  sport        String
  homeTeamId   String   @map("home_team_id")
  awayTeamId   String   @map("away_team_id")
  homeTeamName String
  awayTeamName String
  homeScore    Int?     @map("home_score")
  awayScore    Int?     @map("away_score")
  matchResult  String?
  status       String   @default("scheduled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  features     MatchFeatures[]
  odds         Odds[]
  snapshots    EventSnapshot[]
  mappings     ExternalMatchMap[]

  @@map("Matches")
}

model MatchFeatures {
  id              String   @id @default(cuid())
  matchId         String   @map("match_id")
  sport           String
  homeWorld       Float?
  awayWorld       Float?
  homePhysio      Float?
  awayPhysio      Float?
  homePsycho      Float?
  awayPsycho      Float?
  worldDiff       Float?
  physioDiff      Float?
  psychoDiff      Float?
  featureTime     DateTime @default(now())
  featureVersion  String
  updatedAt       DateTime @updatedAt
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, sport, featureVersion])
}

model Odds {
  id         String   @id @default(cuid())
  matchId    String
  provider   String
  odds_json  Json
  fetched_at DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model EventSnapshot {
  snapshot_id   String   @id @default(uuid()) @db.Uuid
  matchId       String   @map("match_id")
  snapshot_type String
  state_json    Json
  created_at    DateTime @default(now())
  status        String   @default("DRAFT")
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model ExternalMatchMap {
  id          String   @id @default(cuid())
  matchId     String
  provider    String
  extId       String
  match_date  DateTime
  home_team   String
  away_team   String
  created_at  DateTime @default(now())
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([provider, extId])
}

model RawEvents {
  id         String   @id @default(cuid())
  extId      String
  provider   String
  sport      String
  league     String
  payload    Json
  hash       String
  processed  Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([extId, provider])
}

model IngestionState {
  id          String   @id @default(cuid())
  provider    String   @default("thesportsdb")
  sport       String
  league      String
  currentPage Int      @default(1)
  status      String   @default("pending")
  retryCount  Int      @default(0)
  lastRunAt   DateTime @default(now())

  @@unique([provider, sport, league])
}
